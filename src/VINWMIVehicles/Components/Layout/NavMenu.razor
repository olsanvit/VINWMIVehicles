@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">
            <i class="bi bi-car-front me-2"></i>VINWMIVehicles
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-house-door me-2"></i> Dashboard
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="wmi-search">
                        <i class="bi bi-search me-2"></i> WMI Search
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="wmc-search">
                        <i class="bi bi-upc-scan me-2"></i> WMC Search
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="vin-search">
                        <i class="bi bi-car-front me-2"></i> VIN Search
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="custom-vin">
                        <i class="bi bi-pencil-square me-2"></i> Custom VIN
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="history">
                        <i class="bi bi-clock-history me-2"></i> History
                    </NavLink>
                </div>

                <hr class="nav-divider" />

                <div class="nav-item px-3">
                    <span class="nav-link text-muted small">
                        <i class="bi bi-person-circle me-1"></i>@context.User.Identity?.Name
                    </span>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="/logout">
                        <i class="bi bi-box-arrow-right me-2"></i> Odhlásit
                    </a>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/login">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Přihlásit
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/register">
                        <i class="bi bi-person-plus me-2"></i> Registrace
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>

    </nav>
</div>

<style>
    .nav-divider {
        border-color: rgba(255,255,255,.15);
        margin: .5rem 1rem;
    }
</style>
