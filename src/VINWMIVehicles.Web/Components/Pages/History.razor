@page "/history"
@rendermode InteractiveServer
@attribute [Authorize]
@inject EfCoreService<AppDbContextVehicle> DbService
@using SharedServices
@using SharedServices.Services
@using SharedServices.Models.Car

<PageTitle>Historie — VINWMIVehicles</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-clock-history"></i> Historie vyhledávání</h3>
</div>

<!-- Tab switcher -->
<div class="d-flex gap-2 mb-3 ui-anim-fade-up">
    <button class="btn btn-sm @(ActiveTab == "wmi" ? "btn-primary" : "btn-outline-secondary")"
            @onclick='() => SetTab("wmi")'>
        <i class="bi bi-search me-1"></i>WMI / WMC
        @if (WmiEntries != null)
        {
            <span class="badge bg-secondary ms-1">@FilteredWmiEntries.Count</span>
        }
    </button>
    <button class="btn btn-sm @(ActiveTab == "vin" ? "btn-primary" : "btn-outline-secondary")"
            @onclick='() => SetTab("vin")'>
        <i class="bi bi-car-front me-1"></i>VIN
        @if (VinInfos != null)
        {
            <span class="badge bg-secondary ms-1">@FilteredVinInfos.Count</span>
        }
    </button>
</div>

<UiSearchBar @bind-Value="_search"
             Placeholder="@(ActiveTab == "wmi" ? "Hledat kód, zemi, region, výrobce…" : "Hledat VIN, výrobce, model…")"
             OnSearch="() => { }" />

@if (IsLoading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Načítám historii…</span>
    </div>
}
else if (ErrorMessage != null)
{
    <div class="ui-panel ui-anim-fade-up p-3">
        <div class="d-flex align-items-center gap-2 text-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@ErrorMessage</span>
        </div>
    </div>
}
else if (ActiveTab == "wmi")
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-search text-accent"></i>
                WMI / WMC záznamy
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Kód</th>
                        <th>Typ</th>
                        <th>Země</th>
                        <th>Region</th>
                        <th>Výrobci</th>
                    </tr>
                </thead>
                <tbody>
                    @if (WmiEntries == null || !WmiEntries.Any())
                    {
                        <tr><td colspan="5" class="text-muted text-center py-4">Žádné WMI záznamy v databázi.</td></tr>
                    }
                    else if (!FilteredWmiEntries.Any())
                    {
                        <tr><td colspan="5" class="text-muted text-center py-4">Žádné výsledky pro „@_search".</td></tr>
                    }
                    else
                    {
                        @foreach (var e in FilteredWmiEntries)
                        {
                            <tr>
                                <td><code class="fw-bold">@e.Code</code></td>
                                <td><span class="badge bg-secondary">@e.CodeType</span></td>
                                <td class="text-muted small">@(e.CountryISO ?? "—")</td>
                                <td class="text-muted small">@(e.Region ?? "—")</td>
                                <td>
                                    @foreach (var m in e.Manufacturers.Take(3))
                                    {
                                        <span class="badge bg-secondary me-1">@m.Manufacturer?.OfficialName</span>
                                    }
                                    @if (e.Manufacturers.Count > 3)
                                    {
                                        <span class="badge bg-secondary">+@(e.Manufacturers.Count - 3)</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-car-front text-accent"></i>
                VIN záznamy
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>VIN</th>
                        <th>Make</th>
                        <th>Model</th>
                        <th>Rok</th>
                        <th>Poznámka</th>
                    </tr>
                </thead>
                <tbody>
                    @if (VinInfos == null || !VinInfos.Any())
                    {
                        <tr><td colspan="5" class="text-muted text-center py-4">Žádné VIN záznamy v databázi.</td></tr>
                    }
                    else if (!FilteredVinInfos.Any())
                    {
                        <tr><td colspan="5" class="text-muted text-center py-4">Žádné výsledky pro „@_search".</td></tr>
                    }
                    else
                    {
                        @foreach (var v in FilteredVinInfos)
                        {
                            <tr>
                                <td><code class="small">@v.Vin</code></td>
                                <td>@(v.Make ?? "—")</td>
                                <td class="fw-semibold">@(v.Model ?? "—")</td>
                                <td class="text-muted small">@(v.ModelYear ?? "—")</td>
                                <td class="text-muted small" style="max-width:260px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                    @(v.Note?.Length > 80 ? v.Note[..80] + "…" : v.Note ?? "—")
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private string ActiveTab { get; set; } = "wmi";
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }
    private List<WmiEntry>? WmiEntries { get; set; }
    private List<VinInfo>? VinInfos { get; set; }
    private string _search = string.Empty;

    private List<WmiEntry> FilteredWmiEntries =>
        WmiEntries is null ? [] :
        string.IsNullOrWhiteSpace(_search) ? WmiEntries :
        WmiEntries.Where(e =>
            (e.Code?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            e.CodeType.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            (e.CountryISO?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.Region?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            e.Manufacturers.Any(m => m.Manufacturer?.OfficialName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
        ).ToList();

    private List<VinInfo> FilteredVinInfos =>
        VinInfos is null ? [] :
        string.IsNullOrWhiteSpace(_search) ? VinInfos :
        VinInfos.Where(v =>
            (v.Vin?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (v.Make?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (v.Model?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (v.ModelYear?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
        ).ToList();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task SetTab(string tab)
    {
        ActiveTab = tab;
        _search = string.Empty;
        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        ErrorMessage = null;
        try
        {
            if (ActiveTab == "wmi")
                WmiEntries = await DbService.GetWmiEntries(take: 200);
            else
                VinInfos = await DbService.GetVins();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
