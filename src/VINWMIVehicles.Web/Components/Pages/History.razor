@page "/history"
@rendermode InteractiveServer
@attribute [Authorize]
@inject EfCoreService<AppDbContextVehicle> DbService
@using SharedServices
@using SharedServices.Services
@using SharedServices.Models.Car

<PageTitle>Historie</PageTitle>

<div class="container-fluid">
    <h2 class="mb-1"><i class="bi bi-clock-history me-2 text-secondary"></i>Historie vyhledávání</h2>
    <p class="text-muted mb-4">Přehled uložených WMI/WMC kódů a VIN z databáze.</p>

    <ul class="nav nav-tabs mb-3" id="historyTabs">
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "wmi" ? "active" : "")" @onclick='() => SetTab("wmi")'>
                <i class="bi bi-search me-1"></i> WMI / WMC
                @if (WmiEntries != null)
                {
                    <span class="badge bg-secondary ms-1">@FilteredWmiEntries.Count</span>
                }
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == "vin" ? "active" : "")" @onclick='() => SetTab("vin")'>
                <i class="bi bi-car-front me-1"></i> VIN
                @if (VinInfos != null)
                {
                    <span class="badge bg-secondary ms-1">@FilteredVinInfos.Count</span>
                }
            </button>
        </li>
    </ul>

    <div class="row g-2 mb-4">
        <div class="col-md-4">
            <div class="input-group input-group-sm">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input class="form-control" placeholder="@(ActiveTab == "wmi" ? "Hledat kód, zemi, region, výrobce…" : "Hledat VIN, výrobce, model…")"
                       @bind="_search" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(_search))
                {
                    <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                        <i class="bi bi-x"></i>
                    </button>
                }
            </div>
        </div>
    </div>

    @if (IsLoading)
    {
        <PageLoadingSpinner />
    }
    else if (ErrorMessage != null)
    {
        <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage</div>
    }
    else if (ActiveTab == "wmi")
    {
        @if (WmiEntries == null || !WmiEntries.Any())
        {
            <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Žádné WMI záznamy v databázi.</div>
        }
        else if (!FilteredWmiEntries.Any())
        {
            <div class="alert alert-warning"><i class="bi bi-search me-2"></i>Žádné výsledky pro „@_search".</div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Kód</th>
                                <th>Typ</th>
                                <th>Země</th>
                                <th>Region</th>
                                <th>Výrobci</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in FilteredWmiEntries)
                            {
                                <tr>
                                    <td><code class="fw-bold">@e.Code</code></td>
                                    <td><span class="badge bg-primary">@e.CodeType</span></td>
                                    <td>@(e.CountryISO ?? "—")</td>
                                    <td>@(e.Region ?? "—")</td>
                                    <td>
                                        @foreach (var m in e.Manufacturers.Take(3))
                                        {
                                            <span class="badge bg-light text-dark me-1 border">@m.Manufacturer?.OfficialName</span>
                                        }
                                        @if (e.Manufacturers.Count > 3)
                                        {
                                            <span class="badge bg-secondary">+@(e.Manufacturers.Count - 3)</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else
    {
        @if (VinInfos == null || !VinInfos.Any())
        {
            <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>Žádné VIN záznamy v databázi.</div>
        }
        else if (!FilteredVinInfos.Any())
        {
            <div class="alert alert-warning"><i class="bi bi-search me-2"></i>Žádné výsledky pro „@_search".</div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>VIN</th>
                                <th>Make</th>
                                <th>Model</th>
                                <th>Rok</th>
                                <th>Poznámka</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in FilteredVinInfos)
                            {
                                <tr>
                                    <td><code class="small">@v.Vin</code></td>
                                    <td>@(v.Make ?? "—")</td>
                                    <td>@(v.Model ?? "—")</td>
                                    <td>@(v.ModelYear ?? "—")</td>
                                    <td class="text-muted small" style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                        @(v.Note?.Length > 80 ? v.Note[..80] + "…" : v.Note ?? "—")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
</div>

@code {
    private string ActiveTab { get; set; } = "wmi";
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }
    private List<WmiEntry>? WmiEntries { get; set; }
    private List<VinInfo>? VinInfos { get; set; }
    private string _search = string.Empty;

    private List<WmiEntry> FilteredWmiEntries =>
        WmiEntries is null ? [] :
        string.IsNullOrWhiteSpace(_search) ? WmiEntries :
        WmiEntries.Where(e =>
            (e.Code?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            e.CodeType.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            (e.CountryISO?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (e.Region?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            e.Manufacturers.Any(m => m.Manufacturer?.OfficialName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
        ).ToList();

    private List<VinInfo> FilteredVinInfos =>
        VinInfos is null ? [] :
        string.IsNullOrWhiteSpace(_search) ? VinInfos :
        VinInfos.Where(v =>
            (v.Vin?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (v.Make?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (v.Model?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (v.ModelYear?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
        ).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task SetTab(string tab)
    {
        ActiveTab = tab;
        _search = string.Empty;
        await LoadData();
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
    }

    private void ClearSearch()
    {
        _search = string.Empty;
    }

    private async Task LoadData()
    {
        IsLoading = true;
        ErrorMessage = null;
        try
        {
            if (ActiveTab == "wmi")
                WmiEntries = await DbService.GetWmiEntries(take: 200);
            else
                VinInfos = await DbService.GetVins();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
