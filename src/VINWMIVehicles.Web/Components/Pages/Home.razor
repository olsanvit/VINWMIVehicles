@page "/"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>VINWMIVehicles — Dashboard</PageTitle>

<!-- Page header -->
<div class="ui-page-header ui-anim-fade-up">
    <h3>
        <i class="bi bi-car-front"></i>
        Dashboard
    </h3>
    <span class="badge bg-secondary text-muted small">VINWMIVehicles</span>
</div>

<!-- Search tools grid -->
<div class="row g-3 mb-4 ui-anim-fade-up">
    <div class="col-6 col-lg-3">
        <QuickLinkCard Href="/wmi-search"
                       Icon="bi-search"
                       Title="WMI Search"
                       Description="World Manufacturer Identifier (3 znaky)"
                       IconClass="icon-accent" />
    </div>
    <div class="col-6 col-lg-3">
        <QuickLinkCard Href="/wmc-search"
                       Icon="bi-upc-scan"
                       Title="WMC Search"
                       Description="World Manufacturer Code (6 znaků)"
                       IconClass="icon-emerald" />
    </div>
    <div class="col-6 col-lg-3">
        <QuickLinkCard Href="/vin-search"
                       Icon="bi-car-front"
                       Title="VIN Search"
                       Description="Vehicle Identification Number (17 znaků)"
                       IconClass="icon-amber" />
    </div>
    <div class="col-6 col-lg-3">
        <QuickLinkCard Href="/custom-vin"
                       Icon="bi-pencil-square"
                       Title="Custom VIN"
                       Description="Libovolný kód — AI analýza"
                       IconClass="icon-rose" />
    </div>
</div>

<!-- Info panels row -->
<div class="row g-3 ui-anim-fade-up">
    <div class="col-lg-8">
        <div class="ui-panel">
            <div class="ui-panel-header">
                <span class="ui-panel-title">
                    <i class="bi bi-info-circle text-accent"></i>
                    Průvodce kódy vozidel
                </span>
            </div>
            <div class="row g-3 py-2">
                <div class="col-md-4">
                    <div class="d-flex gap-2 align-items-start">
                        <span class="badge bg-primary mt-1">WMI</span>
                        <div>
                            <div class="fw-semibold small">World Manufacturer Identifier</div>
                            <div class="text-muted" style="font-size:12px">První 3 znaky VIN — identifikuje výrobce vozidla po celém světě.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex gap-2 align-items-start">
                        <span class="badge bg-success mt-1">WMC</span>
                        <div>
                            <div class="fw-semibold small">World Manufacturer Code</div>
                            <div class="text-muted" style="font-size:12px">Rozšířený kód (6 znaků) pro přesnější identifikaci výrobce.</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="d-flex gap-2 align-items-start">
                        <span class="badge bg-warning text-dark mt-1">VIN</span>
                        <div>
                            <div class="fw-semibold small">Vehicle Identification Number</div>
                            <div class="text-muted" style="font-size:12px">Kompletní 17místný identifikátor vozidla s AI analýzou.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="d-flex flex-column gap-3">
            <QuickLinkCard Href="/history"
                           Icon="bi-clock-history"
                           Title="Historie vyhledávání"
                           Description="Přehled všech WMI/WMC a VIN vyhledávání"
                           IconClass="icon-cyan" />
            <QuickLinkCard Href="/achievements"
                           Icon="bi-trophy-fill"
                           Title="Achievementy"
                           Description="Odemčené odznaky a body"
                           IconClass="icon-purple" />
        </div>
    </div>
</div>
