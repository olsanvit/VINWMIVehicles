@* AUDIT:OK *@
@page "/wmi-search"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IVehicleSearchService SearchService

<PageTitle>WMI Search — VINWMIVehicles</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-search"></i> WMI Search</h3>
    <span class="text-muted small">World Manufacturer Identifier — 3 znaky</span>
</div>

<!-- Search input -->
<div class="ui-panel ui-anim-fade-up">
    <div class="ui-panel-header">
        <span class="ui-panel-title">
            <i class="bi bi-search text-accent"></i>
            Vyhledat WMI kód
        </span>
    </div>
    <div class="p-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-6">
                <label class="form-label small text-muted">WMI kód (3 znaky)</label>
                <input class="form-control"
                       style="font-family:monospace;font-size:1.1rem;background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.15);color:var(--ui-text-1)"
                       @bind="WmiCode"
                       @bind:event="oninput"
                       @onkeydown="OnKeyDown"
                       placeholder="např. TMB, VF1, WBA"
                       maxlength="3" />
                <div class="mt-1">
                    <small class="text-muted">Zadáno: <strong>@WmiCode.Length</strong>/3 znaků</small>
                </div>
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100" @onclick="Search" disabled="@(IsLoading || WmiCode.Length != 3)">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-search me-1"></i> Hledat
                </button>
            </div>
        </div>
    </div>
</div>

@if (ErrorMessage != null)
{
    <div class="ui-panel ui-anim-fade-up p-3">
        <div class="d-flex align-items-center gap-2 text-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@ErrorMessage</span>
        </div>
    </div>
}

@if (NhtsaResult != null)
{
    <div class="row g-3 ui-anim-fade-up">
        <div class="col-lg-6">
            <div class="ui-panel h-100">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-database text-accent"></i>
                        NHTSA výsledky
                    </span>
                </div>
                <div class="p-3">
                    @if (!NhtsaResult.Results.Any())
                    {
                        <p class="text-muted mb-0">Žádné výsledky z NHTSA.</p>
                    }
                    else
                    {
                        @foreach (var r in NhtsaResult.Results)
                        {
                            <div class="mb-3 pb-3 border-bottom border-opacity-10">
                                <div class="fw-semibold">@r.ManufacturerName</div>
                                <div class="mt-1 d-flex gap-2 flex-wrap">
                                    @if (!string.IsNullOrWhiteSpace(r.Country))
                                    {
                                        <span class="badge bg-secondary"><i class="bi bi-geo-alt me-1"></i>@r.Country</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(r.VehicleTypeName))
                                    {
                                        <span class="badge bg-secondary">@r.VehicleTypeName</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(r.CommonName))
                                {
                                    <p class="small text-muted mt-1 mb-0">@r.CommonName</p>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="ui-panel h-100">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-robot text-accent"></i>
                        AI Analýza
                    </span>
                </div>
                <div class="p-3">
                    <pre class="small mb-0" style="white-space:pre-wrap;word-break:break-word;color:var(--ui-text-1)">@AiResponse</pre>
                </div>
            </div>
        </div>
    </div>

    @if (SavedEntry != null)
    {
        <div class="ui-panel ui-anim-fade-up p-3 mt-2">
            <div class="d-flex align-items-center gap-2 text-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>Uloženo do databáze (kód: <strong>@SavedEntry.Code</strong>)</span>
            </div>
        </div>
    }
}

@code {
    private string WmiCode { get; set; } = "";
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }
    private SharedServices.Models.Car.WmiEntry? SavedEntry { get; set; }
    private VINWMIVehicles.Models.NhtsaWmiResponse? NhtsaResult { get; set; }
    private string AiResponse { get; set; } = "";

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && WmiCode.Length == 3)
            await Search();
    }

    private async Task Search()
    {
        if (WmiCode.Trim().Length != 3) return;
        IsLoading = true;
        ErrorMessage = null;
        NhtsaResult = null;
        SavedEntry = null;
        AiResponse = "";

        try
        {
            var (nhtsa, ai, saved) = await SearchService.SearchWmiAsync(WmiCode.Trim().ToUpperInvariant(), SharedServices.Models.Car.WmiCodeType.WMI);
            NhtsaResult = nhtsa;
            AiResponse = ai;
            SavedEntry = saved;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
