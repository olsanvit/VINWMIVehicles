@* AUDIT:OK *@
@page "/vin-search"
@rendermode InteractiveServer
@attribute [Authorize]
@inject IVehicleSearchService SearchService

<PageTitle>VIN Search — VINWMIVehicles</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-car-front"></i> VIN Search</h3>
    <span class="text-muted small">Vehicle Identification Number — 17 znaků</span>
</div>

<!-- Search input -->
<div class="ui-panel ui-anim-fade-up">
    <div class="ui-panel-header">
        <span class="ui-panel-title">
            <i class="bi bi-car-front text-accent"></i>
            Dekódovat VIN
        </span>
    </div>
    <div class="p-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-7">
                <label class="form-label small text-muted">VIN číslo (17 znaků)</label>
                <input class="form-control"
                       style="font-family:monospace;font-size:1.1rem;letter-spacing:0.05em;background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.15);color:var(--ui-text-1)"
                       @bind="Vin"
                       @bind:event="oninput"
                       @onkeydown="OnKeyDown"
                       placeholder="např. TMBAB12345C678901"
                       maxlength="17" />
                <div class="mt-1">
                    <small class="text-muted">Zadáno: <strong>@Vin.Length</strong>/17 znaků</small>
                </div>
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100" @onclick="Search" disabled="@(IsLoading || Vin.Length != 17)">
                    @if (IsLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-car-front me-1"></i> Dekódovat
                </button>
            </div>
        </div>
    </div>
</div>

@if (ErrorMessage != null)
{
    <div class="ui-panel ui-anim-fade-up p-3">
        <div class="d-flex align-items-center gap-2 text-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@ErrorMessage</span>
        </div>
    </div>
}

@if (NhtsaResult != null)
{
    var keyVars = new[] { "Make", "Model", "Model Year", "Body Class", "Drive Type",
                          "Fuel Type - Primary", "Engine Number of Cylinders", "Displacement (L)",
                          "Manufacturer Name", "Plant Country", "Vehicle Type" };

    <div class="row g-3 ui-anim-fade-up">
        <div class="col-lg-6">
            <div class="ui-panel h-100">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-database text-accent"></i>
                        NHTSA dekódování
                    </span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0">
                        <tbody>
                            @foreach (var v in NhtsaResult.Results.Where(r => keyVars.Contains(r.Variable) && !string.IsNullOrWhiteSpace(r.Value) && r.Value != "Not Applicable"))
                            {
                                <tr>
                                    <td class="text-muted small" style="width:45%">@v.Variable</td>
                                    <td class="small fw-semibold">@v.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (!NhtsaResult.Results.Any(r => keyVars.Contains(r.Variable) && !string.IsNullOrWhiteSpace(r.Value)))
                    {
                        <p class="text-muted p-3 mb-0">Žádné výsledky z NHTSA.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="ui-panel h-100">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-robot text-accent"></i>
                        AI Analýza
                    </span>
                </div>
                <div class="p-3">
                    <p class="small mb-0" style="white-space:pre-wrap;color:var(--ui-text-1)">@AiResponse</p>
                </div>
            </div>
        </div>
    </div>

    @if (SavedVin != null)
    {
        <div class="ui-panel ui-anim-fade-up p-3 mt-2">
            <div class="d-flex align-items-center gap-2 text-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>Uloženo do databáze (VIN: <strong>@SavedVin.Vin</strong>)</span>
            </div>
        </div>
    }
}

@code {
    private string Vin { get; set; } = "";
    private bool IsLoading { get; set; }
    private string? ErrorMessage { get; set; }
    private SharedServices.Models.Car.VinInfo? SavedVin { get; set; }
    private VINWMIVehicles.Models.NhtsaVinResponse? NhtsaResult { get; set; }
    private string AiResponse { get; set; } = "";

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && Vin.Length == 17)
            await Search();
    }

    private async Task Search()
    {
        if (Vin.Trim().Length != 17) return;
        IsLoading = true;
        ErrorMessage = null;
        NhtsaResult = null;
        SavedVin = null;
        AiResponse = "";

        try
        {
            var (nhtsa, ai, saved) = await SearchService.SearchVinAsync(Vin.Trim().ToUpperInvariant());
            NhtsaResult = nhtsa;
            AiResponse = ai;
            SavedVin = saved;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
